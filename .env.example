DATABASE_URL="postgresql://user:password@localhost:5432/bakery"
# Прямое подключение к Postgres (без pooler). На Neon — строка «Direct» из дашборда.
# Локально обычно совпадает с DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/bakery"
JWT_SECRET="your-secret-key-min-32-chars-here"
# Опционально: отдельный секрет для QR бонусов (≥32 символов). Если не задан — используется JWT_SECRET.
# LOYALTY_QR_SECRET="another-secret-min-32-chars-for-loyalty-qr"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# === Яндекс: нужны ДВА разных ключа (developer.tech.yandex.ru) ===
# 1) «API Геосаджеста» → подсказки при вводе улицы
YANDEX_GEOSUGGEST_KEY=
# 2) «HTTP Геокодер» → координаты после выбора адреса из списка
YANDEX_GEOCODER_KEY=
# Если в кабинете Яндекса включено ограничение Referer — домен без https:// :
# YANDEX_GEOCODER_REFERER=https://vkusno-pearl.vercel.app
# Ключ геокодера НЕ работает для подсказок и наоборот.
ADMIN_INIT_KEY="your-init-secret"
# --- iiko Cloud ---
# Единственная обязательная переменная для iiko в .env:
# API-ключ (apiLogin) из личного кабинета iiko.biz
IIKO_API_LOGIN="your-iiko-api-login"
# Не использовать в коде — источник apiLogin: IIKO_API_LOGIN
# IIKO_API_KEY=
# Organization ID и Terminal Group ID в .env не нужны — задаются в админке
# (Настройки → Интеграция iiko) или кнопкой «Загрузить ID из iiko».
IIKO_ORG_ID=
IIKO_TERMINAL_BAKERY=
IIKO_TERMINAL_CAFE=
IIKO_ORDER_TYPE_PICKUP=
IIKO_ORDER_TYPE_DELIVERY=
IIKO_PAYMENT_SBP_ID=
IIKO_MENU_ID=76400

# --- СБП (заполнить после получения доступа от банка) ---
PAYMENT_SBP_API_URL=
PAYMENT_SBP_MERCHANT_ID=
PAYMENT_SBP_API_KEY=
PAYMENT_SBP_WEBHOOK_SECRET=
